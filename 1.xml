<?xml version="1.0" encoding="UTF-8" ?>
<Module>
<ModulePrefs title="Resources" />
<Content type="html"><![CDATA[

<!DOCTYPE html>
<html lang="en-us">
<head>
<meta charset="utf-8"/>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
<style>
  html,body{width:100%;height:100%;padding:0;margin:0;overflow:hidden;}
  .fullscreen-canvas{background:#242424;width:100%;height:100%;position:absolute;top:0;left:0;}
  .loader-container{position:absolute;top:0;left:0;width:100%;height:100%;
    display:flex;justify-content:center;align-items:center;background:#242424;z-index:100;
    transition:opacity .5s ease-in-out,visibility .5s ease-in-out;}
  .loader-content{text-align:center;}
  .logo{width:220px;height:auto;margin-bottom:50px;
    filter:drop-shadow(0 10px 20px rgba(0,0,0,0.5));
    animation:fadeIn .8s ease-out,pulse 2s ease-in-out infinite;}
  .progress-wrap{width:220px;height:6px;background:rgba(255,255,255,.15);
    border-radius:3px;margin:0 auto 12px;overflow:hidden;display:none;}
  .progress-fill{height:100%;width:0%;background:#fff;border-radius:3px;transition:width .2s ease;}
  .progress-label{font-family:sans-serif;font-size:12px;color:rgba(255,255,255,.6);
    letter-spacing:.4px;margin-bottom:18px;min-height:18px;}
  .spinner{width:44px;height:44px;margin:0 auto;
    border:3px solid rgba(255,255,255,.2);border-top:3px solid #fff;border-right:3px solid #fff;
    border-radius:50%;animation:spin 1s linear infinite;}
  @keyframes spin{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}
  @keyframes fadeIn{0%{opacity:0;transform:scale(.95)}100%{opacity:1;transform:scale(1)}}
  @keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.05)}}
  .loader-hidden{opacity:0;visibility:hidden;}
</style>
</head>
<body>

<canvas id="canvas" class="fullscreen-canvas"></canvas>

<div id="loader" class="loader-container">
  <div class="loader-content">
    <img src="logo.png" alt="Logo" class="logo" width="220" loading="eager"
         onerror="this.style.display='none'"/>
    <div class="progress-wrap" id="pWrap"><div class="progress-fill" id="pFill"></div></div>
    <div class="progress-label" id="pLabel"></div>
    <div class="spinner" id="spinner"></div>
  </div>
</div>

<!-- Hata susturucu -->
<script>
window.addEventListener('unhandledrejection',function(e){
  console.log('[Suppressed]',e.reason); e.preventDefault(); return true;
});
window.addEventListener('error',function(e){
  if(e.message&&(e.message.includes('decode audio')||
     e.message.includes('EncodingError')||e.message.includes('FSB failed'))){
    e.preventDefault(); return true;
  }
});
window.alert=(function(orig){
  return function(msg){
    if(msg&&(msg.includes('decode audio')||msg.includes('EncodingError')||
             msg.includes('FSB failed'))) return;
    orig(msg);
  };
})(window.alert);
</script>

<!-- AudioContext unlock -->
<script>
(function(){
  function u(){
    if(window._au)return; window._au=true;
    try{var c=new(window.AudioContext||window.webkitAudioContext)();
      var b=c.createBuffer(1,1,22050);var s=c.createBufferSource();
      s.buffer=b;s.connect(c.destination);s.start(0);c.resume&&c.resume();
    }catch(e){}
    ['touchstart','pointerdown','click'].forEach(function(t){document.removeEventListener(t,u);});
  }
  ['touchstart','pointerdown','click'].forEach(function(t){document.addEventListener(t,u,{passive:true});});
})();
</script>

<!-- keyboard fix -->
<script>
var gameInstance = undefined;
function FixInputOnSubmit(){ document.getElementById("fixInput").blur(); event.preventDefault(); }
function FixInputUpdate()  { gameInstance&&gameInstance.SendMessage('_WebGLKeyboard','ReceiveInputChange',document.getElementById("fixInput").value); }
function FixInputOnBlur()  { gameInstance&&gameInstance.SendMessage('_WebGLKeyboard','LoseFocus'); }
</script>
<div>
  <form onsubmit="FixInputOnSubmit()" autocomplete="off"
        style="width:0;height:0;position:absolute;top:-9999px;">
    <input type="text" id="fixInput" oninput="FixInputUpdate()"
           onblur="FixInputOnBlur()" style="font-size:42px;"/>
  </form>
</div>

<script>
/* ================================================================
   CDN — sadece bunu değiştir
   playgama-bridge-unity.js dosyasını da CDN'e yükle (Build yanına)
   ================================================================ */
var CDN = "https://cdn.jsdelivr.net/gh/createzalma6z/baals@main/";   /* örn: https://cdn.jsdelivr.net/gh/user/repo@main */

var canvas   = document.getElementById('canvas');
var loaderEl = document.getElementById('loader');
var pWrap    = document.getElementById('pWrap');
var pFill    = document.getElementById('pFill');
var pLabel   = document.getElementById('pLabel');
var spinner  = document.getElementById('spinner');

function setProgress(pct,label){
  pWrap.style.display='block'; spinner.style.display='none';
  pFill.style.width=pct.toFixed(1)+'%'; pLabel.textContent=label||'';
}
function hideLoader(){ loaderEl.classList.add('loader-hidden'); }

/* ── PLAYGAMA BRIDGE PROXY (kalici cozum) ─────────────────
   Bridge dosyasi window.getXxx fonksiyonlarini tanimliyor
   ama icinde _bridge nesnesi yok (bridge.playgama.com yok).
   Cozum: window uzerinde Proxy kuruyoruz, bridge set ettigi
   tum fonksiyonlari bizim wrapper'larimizla eziyoruz.
   Ek olarak _JS_CallAsLongAsNoExceptionsSeen icin global
   try-catch ekliyoruz.                                      */

/* 1. Guvenli deger dondurucu - fonksiyon adina gore */
function _pgSafeValue(name) {
  if (name.match(/State$/i))        return 'ready';
  if (name.match(/Supported$/i))    return 'false';
  if (name.match(/Enabled$/i))      return 'false';
  if (name.match(/Allowed$/i))      return 'true';
  if (name.match(/Language$/i))     return 'en';
  if (name.match(/DeviceType$/i))   return 'desktop';
  if (name.match(/PlatformId$/i))   return 'playgama';
  if (name.match(/Initialized$/i))  return 'true';
  if (name.match(/Ready$/i))        return 'true';
  if (name.match(/Authorized$/i))   return 'false';
  if (name.match(/AccountId$/i))    return 'false';
  if (name.match(/Version$/i))      return '1.0';
  if (name.match(/Id$/i))           return '0';
  if (name.match(/Name$/i))         return 'Guest';
  if (name.match(/Avatar/i))        return '';
  if (name.match(/Age$/i))          return '0';
  if (name.match(/Url$/i))          return '';
  if (name.match(/Clipboard$/i))    return '';
  if (name.match(/Width/i))         return 'true';
  return 'false';
}

/* 2. Bridge fonksiyonlarini wrap eden fabrika */
function _pgWrap(name, origFn) {
  return function() {
    try {
      var r = origFn.apply(this, arguments);
      return r;
    } catch(e) {
      console.log('[PG Proxy] ' + name + ' suppressed:', e.message);
      return _pgSafeValue(name);
    }
  };
}

/* 3. Bridge script yukle, sonra TUM window.get/show/set/is fonks. wrap et */
var bridge = document.createElement('script');
bridge.src = CDN + "/playgama-bridge-unity.js";
bridge.onload = function() {
  /* Bridge'in tanimladigi tum PlaygamaBridge fonksiyonlarini bul ve wrap et */
  var pgPattern = /^(get|show|hide|set|send|is|has|can|authorize|purchase|share|invite|join|rate|add|create|consume|delete|flash|haptic)/;
  var wrapped = 0;
  Object.getOwnPropertyNames(window).forEach(function(key) {
    if (pgPattern.test(key) && typeof window[key] === 'function') {
      var orig = window[key];
      window[key] = _pgWrap(key, orig);
      wrapped++;
    }
  });

  /* Eksik kalabilecek fonksiyonlar icin ek guvence */
  var extras = [
    'getPlatformLanguage','getPlatformId','getLanguage','getDeviceType',
    'getVisibilityState','isInitialized','isPlatformReady',
    'getInterstitialState','getNativeInterstitialState',
    'getRewardedState','getNativeRewardedState',
    'canShowBanner','getIsBannerSupported','getBannerState',
    'isAuthorized','hasUserAccountId','getIsExternalLinksAllowed',
    'getIdFromPlayerId','getNameFromPlayerId',
    'getAvatarSmallFromPlayerId','getAvatarMediumFromPlayerId','getAvatarLargeFromPlayerId',
    'getIsGetPlayerDataEnabled','getIsSetPlayerDataEnabled',
    'getPaymentsState','getIsGetProductsEnabled','getIsGetPurchasesEnabled',
    'getIsLeaderboardSupported','getIsNativePopupSupported',
    'getIsMultipleBoardsSupported','getIsSetScoreEnabled',
    'getIsGetScoreEnabled','getIsGetEntriesEnabled',
    'getIsGetFriendsEnabled','getIsInviteFriendsEnabled',
    'getIsJoinCommunityEnabled','getIsShareEnabled','getIsCreatePostEnabled',
    'getIsAddToHomeScreenEnabled','getIsAddToFavoritesEnabled','getIsRateEnabled',
    'getIsHapticFeedbackEnabled','getIsRemoteConfigEnabled',
    'getStoreName','getStoreMinimumAge','getStoreId','getAppId','getAppVersion',
    'getIsMinimumDesktopWidthMatchingCurrentWidth','getClipboard'
  ];
  extras.forEach(function(name) {
    if (typeof window[name] !== 'function') {
      var n = name;
      window[n] = function(){ return _pgSafeValue(n); };
    }
  });

  /* show/set fonksiyonlari - hepsini no-op yap */
  ['showInterstitial','showNativeInterstitial','showRewarded','showNativeRewarded',
   'showBanner','hideBanner','authorize','purchase','getProducts','getPurchases',
   'consumePurchase','getPlayerData','setPlayerData','deletePlayerData',
   'setLeaderboardScore','getLeaderboardEntries','getSocialNetworkFriends','sendMessageToPlatform',
   'shareLink','inviteFriends','joinCommunity','createPost','addToHomeScreen',
   'addToFavorites','rateGame','hapticFeedback','setClipboard'
  ].forEach(function(name) {
    var n = name;
    window[n] = function(){
      var inst = window.unityInstance;
      var cbMap = {
        showInterstitial:      ['PlaygamaBridge','OnInterstitialClose','true'],
        showNativeInterstitial:['PlaygamaBridge','OnNativeInterstitialClose','true'],
        showRewarded:          ['PlaygamaBridge','OnRewardedClose','true'],
        showNativeRewarded:    ['PlaygamaBridge','OnNativeRewardedClose','true'],
        getPlayerData:         ['PlaygamaBridge','OnGetPlayerDataComplete','{}'],
        setPlayerData:         ['PlaygamaBridge','OnSetPlayerDataComplete','true'],
        deletePlayerData:      ['PlaygamaBridge','OnDeletePlayerDataComplete','true'],
        getProducts:           ['PlaygamaBridge','OnGetProductsComplete','[]'],
        getPurchases:          ['PlaygamaBridge','OnGetPurchasesComplete','[]'],
        getLeaderboardEntries: ['PlaygamaBridge','OnGetLeaderboardEntriesComplete','[]']
      };
      var cb = cbMap[n];
      if (cb && inst) {
        setTimeout(function(){
          try{ inst.SendMessage(cb[0],cb[1],cb[2]); }catch(e){}
        },100);
      }
    };
  });

  console.log('[PG Proxy] Bridge wrapped and patched.');



  /* Platform */
  window.getPlatformId           = function(){ return 'playgama'; };
  window.getLanguage             = function(){ return 'en'; };
  window.getDeviceType           = function(){ return 'desktop'; };
  window.getVisibilityState      = function(){ return 'visible'; };
  window.isInitialized           = function(){ return 'true'; };
  window.isPlatformReady         = function(){ return 'true'; };
  window.getIsMinimumDesktopWidthMatchingCurrentWidth = function(){ return 'true'; };

  /* Player */
  window.isAuthorized            = function(){ return 'false'; };
  window.hasUserAccountId        = function(){ return 'false'; };
  window.getIsExternalLinksAllowed = function(){ return 'true'; };
  window.getIdFromPlayerId       = function(){ return '0'; };
  window.getNameFromPlayerId     = function(){ return 'Guest'; };
  window.getAvatarSmallFromPlayerId  = function(){ return ''; };
  window.getAvatarMediumFromPlayerId = function(){ return ''; };
  window.getAvatarLargeFromPlayerId  = function(){ return ''; };
  window.getIsGetPlayerDataEnabled   = function(){ return 'false'; };
  window.getIsSetPlayerDataEnabled   = function(){ return 'false'; };

  /* Ads — interstitial */
  window.getInterstitialState       = function(){ return 'ready'; };
  window.getNativeInterstitialState = function(){ return 'ready'; };
  window.showInterstitial = function(){
    setTimeout(function(){
      try{ window.unityInstance&&window.unityInstance.SendMessage('PlaygamaBridge','OnInterstitialClose','true'); }catch(e){}
    },200);
  };
  window.showNativeInterstitial = function(){
    setTimeout(function(){
      try{ window.unityInstance&&window.unityInstance.SendMessage('PlaygamaBridge','OnNativeInterstitialClose','true'); }catch(e){}
    },200);
  };

  /* Ads — rewarded */
  window.getRewardedState        = function(){ return 'ready'; };
  window.getNativeRewardedState  = function(){ return 'ready'; };
  window.showRewarded = function(){
    setTimeout(function(){
      try{
        window.unityInstance&&window.unityInstance.SendMessage('PlaygamaBridge','OnRewardedReward','reward');
        window.unityInstance&&window.unityInstance.SendMessage('PlaygamaBridge','OnRewardedClose','true');
      }catch(e){}
    },200);
  };
  window.showNativeRewarded = function(){
    setTimeout(function(){
      try{
        window.unityInstance&&window.unityInstance.SendMessage('PlaygamaBridge','OnNativeRewardedReward','reward');
        window.unityInstance&&window.unityInstance.SendMessage('PlaygamaBridge','OnNativeRewardedClose','true');
      }catch(e){}
    },200);
  };

  /* Ads — banner */
  window.canShowBanner           = function(){ return 'false'; };
  window.getIsBannerSupported    = function(){ return 'false'; };
  window.getBannerState          = function(){ return 'hidden'; };
  window.showBanner              = function(){};
  window.hideBanner              = function(){};

  /* Payments */
  window.getPaymentsState        = function(){ return 'not_supported'; };
  window.getIsGetProductsEnabled = function(){ return 'false'; };
  window.getIsGetPurchasesEnabled= function(){ return 'false'; };
  window.purchase                = function(){
    try{ window.unityInstance&&window.unityInstance.SendMessage('PlaygamaBridge','OnPurchaseFailed',''); }catch(e){}
  };
  window.getProducts             = function(){
    try{ window.unityInstance&&window.unityInstance.SendMessage('PlaygamaBridge','OnGetProductsComplete','[]'); }catch(e){}
  };
  window.getPurchases            = function(){
    try{ window.unityInstance&&window.unityInstance.SendMessage('PlaygamaBridge','OnGetPurchasesComplete','[]'); }catch(e){}
  };
  window.consumePurchase         = function(){};

  /* Cloud save */
  window.getPlayerData           = function(){
    try{ window.unityInstance&&window.unityInstance.SendMessage('PlaygamaBridge','OnGetPlayerDataComplete','{}'); }catch(e){}
  };
  window.setPlayerData           = function(){
    try{ window.unityInstance&&window.unityInstance.SendMessage('PlaygamaBridge','OnSetPlayerDataComplete','true'); }catch(e){}
  };
  window.deletePlayerData        = function(){
    try{ window.unityInstance&&window.unityInstance.SendMessage('PlaygamaBridge','OnDeletePlayerDataComplete','true'); }catch(e){}
  };

  /* Leaderboard */
  window.getIsLeaderboardSupported    = function(){ return 'false'; };
  window.getIsNativePopupSupported    = function(){ return 'false'; };
  window.getIsMultipleBoardsSupported = function(){ return 'false'; };
  window.getIsSetScoreEnabled         = function(){ return 'false'; };
  window.getIsGetScoreEnabled         = function(){ return 'false'; };
  window.getIsGetEntriesEnabled       = function(){ return 'false'; };
  window.setLeaderboardScore          = function(){};
  window.getLeaderboardEntries        = function(){
    try{ window.unityInstance&&window.unityInstance.SendMessage('PlaygamaBridge','OnGetLeaderboardEntriesComplete','[]'); }catch(e){}
  };

  /* Social */
  window.getIsGetFriendsEnabled       = function(){ return 'false'; };
  window.getIsInviteFriendsEnabled    = function(){ return 'false'; };
  window.getIsJoinCommunityEnabled    = function(){ return 'false'; };
  window.getIsShareEnabled            = function(){ return 'false'; };
  window.getIsCreatePostEnabled       = function(){ return 'false'; };
  window.getIsAddToHomeScreenEnabled  = function(){ return 'false'; };
  window.getIsAddToFavoritesEnabled   = function(){ return 'false'; };
  window.getIsRateEnabled             = function(){ return 'false'; };
  window.getSocialNetworkFriends      = function(){};
  window.shareLink                    = function(){};
  window.inviteFriends                = function(){};
  window.joinCommunity                = function(){};
  window.createPost                   = function(){};
  window.addToHomeScreen              = function(){};
  window.addToFavorites               = function(){};
  window.rateGame                     = function(){};

  /* Store */
  window.getStoreName                 = function(){ return 'unknown'; };
  window.getStoreMinimumAge           = function(){ return '0'; };
  window.getStoreId                   = function(){ return ''; };
  window.getAppId                     = function(){ return '0'; };
  window.getAppVersion                = function(){ return '1.0'; };

  /* Auth */
  window.authorize                    = function(){
    try{ window.unityInstance&&window.unityInstance.SendMessage('PlaygamaBridge','OnAuthorizeComplete','false'); }catch(e){}
  };

  /* Misc */
  window.getIsHapticFeedbackEnabled   = function(){ return 'false'; };
  window.hapticFeedback               = function(){};
  window.getIsRemoteConfigEnabled     = function(){ return 'false'; };
  window.getClipboard                 = function(){ return ''; };
  window.setClipboard                 = function(){};
  window.flashSaleState               = function(){ return 'not_supported'; };

  console.log('[Bridge Override] All Playgama stubs applied (' +
    Object.keys(window).filter(function(k){ return typeof window[k]==='function'&&k.match(/^(get|show|hide|set|send|is|has|can|authorize|purchase|share|invite|join|rate|add|create|consume|delete|flash|haptic)/); }).length + ' funcs).');

  /* 2. Sonra Unity loader */
  var unityLoader = document.createElement('script');
  unityLoader.src = CDN + "/Build/SOCCER 2026.loader.js";
  unityLoader.onload = function() {
    createUnityInstance(canvas, {
      dataUrl:            CDN + "/Build/SOCCER 2026.data.unityweb",
      frameworkUrl:       CDN + "/Build/SOCCER 2026.framework.js.unityweb",
      codeUrl:            CDN + "/Build/SOCCER 2026.wasm.unityweb",
      streamingAssetsUrl: CDN + "/StreamingAssets",
      companyName:        "",
      productName:        "SOCCER 2026",
      productVersion:     "1.0"
    }, function(progress){
      setProgress(progress*100,
        progress<1 ? 'Yükleniyor... '+Math.round(progress*100)+'%' : '');
    }).then(function(inst){
      gameInstance = inst;
      window.unityInstance = inst;
      hideLoader();
    }).catch(function(msg){ console.error('Unity error:',msg); });
  };
  unityLoader.onerror = function(){ pLabel.textContent='Loader yüklenemedi'; };
  document.body.appendChild(unityLoader);
};
bridge.onerror = function(){ pLabel.textContent='Bridge yüklenemedi — CDN kontrol et'; };
document.body.appendChild(bridge);

document.addEventListener('pointerdown',function(){ canvas.focus(); window.focus(); });
</script>
<!-- Sticky Bottom Center Ad (728x90) with Smooth Slide-Out and Reappearance -->
<style>

</script>
</body>
</html>

]]></Content>
